# Generous fetch timeouts so downloads on slow connections do not stall forever.
# This prevents `npm install` from hanging indefinitely when downloading large
# binaries such as the Electron runtime (~100 MB from GitHub releases).
fetch-timeout=300000
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# To use an alternative Electron download mirror (e.g. in restricted networks),
# set the ELECTRON_MIRROR environment variable before running npm install:
#   ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ npm install
#
# To skip the Electron binary download entirely (e.g. in CI where you only run
# unit tests), set: ELECTRON_SKIP_BINARY_DOWNLOAD=1
