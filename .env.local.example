# Google Drive Integration (optional)
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/
# Enable the Google Drive API and add your domain to Authorized JavaScript origins.
# Copy this file to .env.local and set your client ID to enable Google Drive sync.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth2-client-id.apps.googleusercontent.com
